---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import experiences from "../data/experience.json";
import { Image } from "astro:assets";
import profileData from "../data/profile.json";
import myPicture from "../assets/photo-profile.webp";

// 1. We strictly define the shape of our JSON data.
// If you misspell a key in the JSON, TypeScript will throw an error here during build time.
interface Experience {
    id: string;
    role: string;
    company: string;
    duration: string;
    description: string;
}

// 2. We assert that our imported JSON matches this exact structure.
const typedExperiences: Experience[] = experiences;
---

<BaseLayout
    title="Kurnia Sani | Home"
    description="The personal portfolio of Kurnia Sani, a software engineer specializing in high-performance web applications and machine learning."
>
    <section class="mb-16 flex flex-col md:flex-row items-center gap-8">
        <Image
            src={myPicture}
            alt="Muhammad Kurnia Sani"
            width={150}
            height={150}
            loading="eager"
            class="rounded-full grayscale hover:grayscale-0 transition-all duration-500 shadow-md"
        />

        <h1 class="text-4xl font-extrabold tracking-tight mb-4">
            {profileData.hero.headline}
        </h1>
        <p class="text-lg text-slate-600 leading-relaxed">
            {profileData.hero.bio}
        </p>
    </section>

    <section>
        <h2 class="text-2xl font-semibold mb-6 border-b border-slate-200 pb-2">
            Experience
        </h2>

        <div class="space-y-8">
            {
                typedExperiences.map((job) => (
                    <div class="group">
                        <h3 class="text-lg font-medium text-slate-800">
                            {job.role}
                        </h3>
                        <div class="text-sm text-slate-500 mb-2 font-mono">
                            {job.company} &bull; {job.duration}
                        </div>
                        <p class="text-slate-600 leading-relaxed">
                            {job.description}
                        </p>
                    </div>
                ))
            }
        </div>
    </section>
</BaseLayout>
