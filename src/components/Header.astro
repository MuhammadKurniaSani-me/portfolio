---
// src/components/Header.astro

import profileData from "../data/profile.json";

// Create the WhatsApp URL with a pre-filled message
const waUrl = `https://wa.me/${profileData.contact.whatsapp}?text=${encodeURIComponent(profileData.contact.message)}`;
---

<header class="w-full py-6 px-4 md:px-8 max-w-5xl mx-auto">
    <div class="flex items-center justify-between">
        <a href="/portfolio" class="text-2xl font-bold tracking-tight text-slate-900"
            >{profileData.hero.name}</a
        >

        <nav
            class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-600"
        >
            <a href="/portfolio" class="hover:text-slate-900 transition-colors">Home</a>
            <a href="/portfolio/projects" class="hover:text-slate-900 transition-colors"
                >Projects</a
            >
            <a
                href="/portfolio/architecture"
                class="hover:text-slate-900 transition-colors">Architecture</a
            >

            <div
                class="flex items-center gap-4 ml-2 border-l border-slate-200 pl-6"
            >
                <a
                    href={`mailto:${profileData.contact.email}`}
                    class="text-slate-400 hover:text-slate-900 transition-colors"
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                        ></path></svg
                    >
                </a>
                <a
                    href={waUrl}
                    title="WhatsApp Me"
                    target="_blank"
                    class="text-slate-400 hover:text-green-600 transition-colors"
                >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                        ><path
                            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                        ></path></svg
                    >
                </a>
            </div>
        </nav>

        <button
            id="mobile-menu-btn"
            class="md:hidden flex items-center p-2 text-slate-600 hover:text-slate-900 focus:outline-none rounded-lg hover:bg-slate-100 transition-colors"
        >
            <svg
                id="icon-menu"
                class="w-6 h-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg
                id="icon-close"
                class="w-6 h-6 hidden"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
    </div>

    <div
        id="mobile-menu"
        class="hidden md:hidden flex-col gap-4 mt-4 bg-slate-50/80 backdrop-blur-md p-6 rounded-2xl border border-slate-200 shadow-lg transition-all"
    >
        <a
            href="/portfolio"
            class="text-base font-medium text-slate-700 hover:text-slate-900"
            >Home</a
        >
        <a
            href="/portfolio/projects"
            class="text-base font-medium text-slate-700 hover:text-slate-900"
            >Projects</a
        >
        <a
            href="/portfolio/architecture"
            class="text-base font-medium text-slate-700 hover:text-slate-900"
            >Architecture</a
        >
        <div class="h-px w-full bg-slate-200 my-2"></div>
        <div class="flex items-center gap-6">
            <a
                href={`mailto:${profileData.contact.email}`}
                title="Email Me"
                class="text-slate-500 hover:text-slate-900">Email Me!</a
            >
            <a
                href={waUrl}
                title="WhatsApp Me"
                target="_blank"
                class="text-slate-500 hover:text-green-600">WhatsApp Me!</a
            >
        </div>
    </div>
</header>

<script>
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const iconMenu = document.getElementById("icon-menu");
    const iconClose = document.getElementById("icon-close");

    if (btn && menu && iconMenu && iconClose) {
        btn.addEventListener("click", () => {
            // Toggle menu visibility
            menu.classList.toggle("hidden");
            menu.classList.toggle("flex");

            // Swap icons (Hamburger <-> X)
            iconMenu.classList.toggle("hidden");
            iconClose.classList.toggle("hidden");
        });
    }
</script>
